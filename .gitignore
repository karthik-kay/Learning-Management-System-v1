# ---------------------------------------------------------------------------
# Secrets and local configuration
# ---------------------------------------------------------------------------
**/.env
**/.env.*
!**/.env.example
!**/env.example
*.pem
*.key
*.p12
*.pfx

# ---------------------------------------------------------------------------
# JavaScript dependencies and package-manager caches
# ---------------------------------------------------------------------------
**/node_modules/
/.pnpm-store/
**/.pnp
**/.pnp.*
**/.yarn/cache/
**/.yarn/unplugged/
**/.yarn/install-state.gz

# ---------------------------------------------------------------------------
# Python environments and caches
# ---------------------------------------------------------------------------
**/venv/
**/.venv/
**/env/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# Framework build output and generated artifacts
# ---------------------------------------------------------------------------
**/.next/
**/out/
**/build/
**/dist/
**/coverage/
**/.coverage
**/htmlcov/
**/.turbo/
**/.vercel/
*.tsbuildinfo
next-env.d.ts

# ---------------------------------------------------------------------------
# Runtime data: databases, uploads, exports, collected static files
# ---------------------------------------------------------------------------
*.sqlite3
db.sqlite3
/backend/django-service/media/
/backend/django-service/staticfiles/

# Runtime uploads must never be stored with shipped frontend assets.
/frontend/public/uploads/
/frontend/public/user-content/

# ---------------------------------------------------------------------------
# Logs and temporary files
# ---------------------------------------------------------------------------
*.log
logs/
*.pid
*.seed
*.tmp
*.temp
*.swp
*.swo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ---------------------------------------------------------------------------
# Local tooling, editor state, and repository analysis scratch data
# ---------------------------------------------------------------------------
/.agents/
/.codex/
/.vscode/
**/.idea/
*.sublime-project
*.sublime-workspace
/_analysis/

# ---------------------------------------------------------------------------
# Operating-system metadata
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
